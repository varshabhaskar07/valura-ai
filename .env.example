# --- LLM ---
# Used in dev. Tests do NOT require this — the LLM is mocked.
OPENAI_API_KEY=

# Model selection. Defaults match the assignment:
#   - dev: gpt-4o-mini (cheap)
#   - eval: gpt-4.1
VALURA_MODEL=gpt-4o-mini

# --- Pipeline ---
# Hard timeout (seconds) for the full request (safety + classifier + agent).
VALURA_REQUEST_TIMEOUT_S=12

# Classifier-only timeout (seconds). Falls back to heuristic on expiry.
VALURA_CLASSIFIER_TIMEOUT_S=4

# Number of prior turns from session memory passed to the classifier.
VALURA_HISTORY_TURNS=3

# --- Server ---
VALURA_HOST=127.0.0.1
VALURA_PORT=8000
VALURA_LOG_LEVEL=INFO
